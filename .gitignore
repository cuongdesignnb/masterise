# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production
.env.*.local
# Keep these in git:
!.env.docker
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ===== Docker =====
docker-compose.override.yml

# ===== Laravel Backend =====
backend/vendor/
backend/node_modules/
backend/.env
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
backend/storage/logs/*
backend/bootstrap/cache/*
!backend/storage/framework/cache/.gitkeep
!backend/storage/framework/sessions/.gitkeep
!backend/storage/framework/views/.gitkeep
!backend/storage/logs/.gitkeep
!backend/bootstrap/cache/.gitkeep
backend/.phpunit.cache
backend/storage/app/public/*
!backend/storage/app/public/.gitkeep
